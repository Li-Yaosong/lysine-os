api-version: 1
name: iana-etc
version: "20241206"
release: 1

description: Network services and protocols database
homepage: https://www.iana.org/protocols
license: OFL-1.1

sources:
  - url: https://github.com/Mic92/iana-etc/releases/download/20241206/iana-etc-20241206.tar.xz
    hash: sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

build:
  install: |
    install -d "$DESTDIR/etc"
    install -m 644 services "$DESTDIR/etc/services"
    install -m 644 protocols "$DESTDIR/etc/protocols"

maintainer: LysineOS Team <team@lysine-os.org>
tags: [network, core]
