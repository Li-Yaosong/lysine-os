api-version: 1
name: kbd
version: 2.6.12
release: 1
description: Keyboard and console utilities for Linux
homepage: https://github.com/legionus/kbd
license: GPL-2.0-or-later
depends:
  runtime:
    - glibc
    - ncurses
sources:
  - url: https://github.com/legionus/kbd/releases/download/v2.6.12/kbd-2.6.12.tar.xz
    hash: sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
build:
  prepare: |
    ./configure --prefix=/usr --disable-static
  compile: |
    make -j$NPROC
  install: |
    make DESTDIR="$DESTDIR" install
