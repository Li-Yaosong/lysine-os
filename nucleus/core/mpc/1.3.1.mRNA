api-version: 1
name: mpc
version: 1.3.1
release: 1
description: Complex number arithmetic library with correct rounding
homepage: https://www.multiprecision.org/
license: GPL-3.0-or-later
depends:
  build:
    - gmp >= 6.3
    - mpfr >= 4.2
  runtime:
    - glibc
    - gmp >= 6.3
    - mpfr >= 4.2
sources:
  - url: https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz
    hash: sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
build:
  prepare: |
    ./configure --prefix=/usr --disable-static
  compile: |
    make -j$NPROC
  check: |
    make check
  install: |
    make DESTDIR="$DESTDIR" install
post-install: ldconfig
outputs:
  main:
    description: MPC complex arithmetic library
  lib:
    description: Runtime libraries
    files:
      - /usr/lib/libmpc.so*
  dev:
    description: Development headers
    files:
      - /usr/include/mpc.h
      - /usr/lib/pkgconfig/mpc.pc
