api-version: 1
name: ninja
version: 1.12.1
release: 1
description: Small build system with focus on speed
homepage: https://ninja-build.org/
license: Apache-2.0
depends:
  runtime:
    - glibc
sources:
  - url: https://github.com/ninja-build/ninja/archive/refs/tags/v1.12.1.tar.gz
    hash: sha256:821bdff48a3f683bc4bb3b6f0b5fe7b2d647cf65d52aeb63328c91a6c6df285a
build:
  prepare: |
    python3 configure.py --prefix=/usr --bootstrap
  install: |
    install -Dm755 ninja "$DESTDIR/usr/bin/ninja"
