api-version: 1
name: xz
version: 5.6.2
release: 1
description: XZ compression utilities
homepage: https://tukaani.org/xz/
license: 0BSD
depends:
  runtime:
    - glibc
sources:
  - url: https://tukaani.org/xz/xz-5.6.2.tar.xz
    hash: sha256:a9db3bb3d64e248a0fae963f8fb6ba851a26ba1822e504dc0efd18a80c626caf
build:
  prepare: |
    ./configure --prefix=/usr --disable-static
  compile: |
    make -j$NPROC
  install: |
    make DESTDIR="$DESTDIR" install
