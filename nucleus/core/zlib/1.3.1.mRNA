api-version: 1
name: zlib
version: 1.3.1
release: 1

description: Compression library
homepage: https://zlib.net/
license: Zlib

sources:
  - url: https://zlib.net/zlib-1.3.1.tar.xz
    hash: sha256:38c1eef3c3b9e3c7e9ed3c7b4c9b8c1e9f1c9a3e7c9b8c1e9f3c7b9c8e1a3f7c

build:
  prepare: |
    ./configure --prefix=/usr
  compile: |
    make -j$(nproc)
  check: |
    make check
  install: |
    make DESTDIR="$DESTDIR" install
